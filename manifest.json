{
  "manifest_version": 3,
  "name": "c_manager_android",
  "version": "0.1.0",
  "description": "Starter Firefox extension scaffold for Android-compatible WebExtensions.",
  "browser_specific_settings": {
    "gecko": {
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      },
      "id": "c-manager-android@example.com",
      "strict_min_version": "142.0"
    },
    "gecko_android": {}
  },
  "action": {
    "default_title": "c_manager_android"
  },
  "content_scripts": [
    {
      "matches": [
        "*://mozilla.org/*",
        "*://*.mozilla.org/*"
      ],
      "js": [
        "borderify.js"
      ]
    }
  ]
}