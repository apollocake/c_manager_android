{
  "manifest_version": 3,
  "name": "c_manager_android",
  "version": "0.1.0",
  "description": "Starter Firefox extension scaffold for Android-compatible WebExtensions.",
  "browser_specific_settings": {
    "gecko": {
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      },
      "id": "c-manager-android@example.com",
      "strict_min_version": "142.0"
    },
    "gecko_android": {}
  },
  "permissions": ["storage"],
  "options_ui": {
    "page": "settings.html",
    "browser_style": false
  },
  "action": {
    "default_title": "c_manager_android"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "css": [
        "injector.css"
      ],
      "js": [
        "injector.resources.js",
        "injector.js"
      ]
    }
  ]
}